{
  "name": "driving-school-frontend",
  "version": "1.0.0",
  "description": "驾校场地监管系统前端",
  "scripts": {
    "dev": "vite --port 3000 --host",
    "dev:stable": "vite --port 3000 --host --clearScreen false --force",
